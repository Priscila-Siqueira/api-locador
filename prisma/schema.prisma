generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model endereco_locador {
  locador_id  BigInt  @id
  logradouro  String  @db.VarChar(150)
  numero      String  @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String  @db.VarChar(100)
  cidade      String  @db.VarChar(100)
  estado      String  @db.VarChar(2)
  cep         String  @db.VarChar(9)
  locador     locador @relation(fields: [locador_id], references: [id], onDelete: Cascade, map: "fk_endereco_locador")
}

model locador {
  id               BigInt            @id @default(autoincrement())
  usuario_id       BigInt
  nome             String            @db.VarChar(150)
  cpf              String            @unique(map: "cpf") @db.VarChar(14)
  email            String            @unique(map: "email") @db.VarChar(150)
  status           locador_status    @default(ATIVO)
  criado_em        DateTime          @default(now()) @db.DateTime(0)
  atualizado_em    DateTime          @default(now()) @db.DateTime(0)
  endereco_locador endereco_locador?

  @@index([usuario_id], map: "idx_locador_usuario_id")
}

enum locador_status {
  ATIVO
  INATIVO
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model contrato_locacao {
  id            BigInt                  @id @default(autoincrement())
  locador_id    BigInt
  imovel_id     Int
  locatario_id  BigInt
  data_inicio   DateTime                @db.Date
  data_fim      DateTime                @db.Date
  data_reajuste DateTime?               @db.Date
  valor_aluguel Decimal                 @db.Decimal(10, 2)
  status        contrato_locacao_status @default(ATIVO)
  locador       locador                 @relation(fields: [locador_id], references: [id], map: "fk_contrato_locador")

  @@index([imovel_id], map: "idx_contrato_locacao_imovel_id")
  @@index([locador_id], map: "idx_contrato_locacao_locador_id")
  @@index([locatario_id], map: "idx_contrato_locacao_locatario_id")
  @@index([status], map: "idx_contrato_locacao_status")
}

model endereco_locador {
  locador_id  BigInt  @id
  logradouro  String  @db.VarChar(150)
  numero      String  @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String  @db.VarChar(100)
  cidade      String  @db.VarChar(100)
  estado      String  @db.VarChar(2)
  cep         String  @db.VarChar(9)
  locador     locador @relation(fields: [locador_id], references: [id], onDelete: Cascade, map: "fk_endereco_locador")
}

model locador {
  id               BigInt             @id @default(autoincrement())
  usuario_id       BigInt
  nome             String             @db.VarChar(150)
  cpf              String             @unique(map: "cpf") @db.VarChar(14)
  email            String             @unique(map: "email") @db.VarChar(150)
  status           locador_status     @default(ATIVO)
  criado_em        DateTime           @default(now()) @db.DateTime(0)
  atualizado_em    DateTime           @default(now()) @db.DateTime(0)
  contrato_locacao contrato_locacao[]
  endereco_locador endereco_locador?

  @@index([usuario_id], map: "idx_locador_usuario_id")
}

enum locador_status {
  ATIVO
  INATIVO
}

enum contrato_locacao_status {
  ATIVO
  ENCERRADO
  RESCINDIDO
}
